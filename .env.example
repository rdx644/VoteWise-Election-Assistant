# VoteWise Environment Configuration
# Copy to .env and fill in values

# Google Services
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_BUCKET_NAME=
GCS_LOCATION=us-central1

# App Config
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=INFO

# Feature Modes
DATABASE_MODE=memory
TTS_MODE=browser

# Security
ADMIN_API_KEY=
ALLOWED_ORIGINS=
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20
